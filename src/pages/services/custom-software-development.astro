---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import CTASection from "../../components/shared/CTASection.astro";
import FAQ from "../../components/shared/FAQ.astro";
import RelatedServices from "../../components/shared/RelatedServices.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import { cognexaServices } from "../../data/services";
import type { FAQ as FAQType } from "../../data/faqs";

const related = cognexaServices
  .filter((s) => !["custom-software-development"].includes(s.slug))
  .slice(0, 3)
  .map((s) => ({ name: s.name, summary: s.summary, href: `/services/${s.slug}/` }));

const faqs: FAQType[] = [
  { question: "What types of software do you build?", answer: "We build internal dashboards, customer portals, workflow tools, data pipelines, mobile apps, and API integrations. We focus on practical business software that solves specific operational problems — not generic platforms." },
  { question: "What technologies do you use?", answer: "We choose technologies based on your requirements and team capabilities. Common choices include Python, Node.js, React, and standard databases. We favour maintainable, well-supported technology over novelty." },
  { question: "Do you offer fixed-price or time-and-materials engagements?", answer: "We offer both. Fixed-scope projects with clear requirements can be quoted at a fixed price. For more exploratory work, we offer time-and-materials with regular deliverables and clear milestones." },
  { question: "Can you integrate with our existing ERP or CRM?", answer: "Yes. ERP and CRM integrations are common — we have experience with SAP, Tally, Salesforce, and custom systems. We assess the integration surface early in the project to identify complexity and risk." },
];
---

<MarketingLayout
  title="Custom Software Development Services in India | CogNexa"
  description="Purpose-built dashboards, portals, automation tools, and integrations for your business. CogNexa builds practical software that solves real operational problems."
>
  <div class="bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
      <Breadcrumbs
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Services", href: "/services/" },
          { label: "Custom Software Development" },
        ]}
        variant="dark"
      />
    </div>

    <section class="pt-8 pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-cyan-400 uppercase tracking-widest mb-3">Custom Development</p>
          <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5 text-balance">
            Custom Software Built for Your Business
          </h1>
          <p class="text-lg text-slate-300 leading-relaxed mb-8">
            Off-the-shelf software rarely fits your exact process. CogNexa builds purpose-built software — dashboards, portals, workflow tools, and integrations — designed around how your business actually works.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact/" class="inline-flex items-center justify-center px-7 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-colors" data-event="cta_click" data-location="hero" data-service="Custom Software Development">
              Discuss Your Project
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">What we build</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {[
            { title: "Internal Dashboards", desc: "Custom reporting and analytics dashboards pulling from your existing systems." },
            { title: "Customer Portals", desc: "Web portals for customers, distributors, or partners to access information and submit requests." },
            { title: "Workflow Tools", desc: "Approval workflows, task management, and process tracking built for your exact process." },
            { title: "ERP / CRM Integrations", desc: "Connect disparate systems so data flows automatically without manual re-entry." },
            { title: "Mobile Applications", desc: "Field-ready mobile apps for sales teams, technicians, delivery staff, or inspectors." },
            { title: "Data Pipelines", desc: "Automated data collection, transformation, and loading between systems." },
          ].map((item) => (
            <div class="rounded-xl bg-slate-800 border border-slate-700 p-6">
              <h3 class="font-bold text-white mb-2">{item.title}</h3>
              <p class="text-sm text-slate-400 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <FAQ items={faqs} variant="dark" />
    <RelatedServices title="Other Services" items={related} variant="dark" />
    <CTASection
      title="Have a specific software problem?"
      description="Tell us what you need to build. We will scope it honestly and tell you what is practical within your timeline and budget."
      primaryLabel="Discuss Your Project"
      primaryHref="/contact/"
      variant="blue"
    />
  </div>
</MarketingLayout>
