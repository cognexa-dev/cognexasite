---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import CTASection from "../../components/shared/CTASection.astro";
import FAQ from "../../components/shared/FAQ.astro";
import RelatedServices from "../../components/shared/RelatedServices.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import { cognexaServices } from "../../data/services";
import type { FAQ as FAQType } from "../../data/faqs";

const related = cognexaServices
  .filter((s) => !["it-consulting"].includes(s.slug))
  .slice(0, 3)
  .map((s) => ({ name: s.name, summary: s.summary, href: `/services/${s.slug}/` }));

const faqs: FAQType[] = [
  { question: "What does an IT consulting engagement look like?", answer: "Typically we start with a discovery session to understand your current setup, challenges, and goals. We then deliver a clear assessment with prioritized recommendations. Engagements can be one-off advisory or ongoing retained consulting." },
  { question: "Do you replace our existing IT team?", answer: "No. We are designed to supplement or support existing IT teams — handling specialist advisory, project oversight, or specific technology decisions that your internal team may not have depth in." },
  { question: "Can you help with vendor selection?", answer: "Yes. We provide vendor-neutral advice for hardware, software, cloud, and connectivity decisions. We have no commercial relationships with vendors that would bias our recommendations." },
];
---

<MarketingLayout
  title="IT Consulting & Infrastructure Services in India | CogNexa"
  description="Strategic IT consulting, infrastructure planning, and managed IT support for businesses in India. Vendor-neutral advice from experienced practitioners."
>
  <div class="bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
      <Breadcrumbs
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Services", href: "/services/" },
          { label: "IT Consulting" },
        ]}
        variant="dark"
      />
    </div>

    <section class="pt-8 pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-cyan-400 uppercase tracking-widest mb-3">IT Consulting</p>
          <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5 text-balance">
            IT Consulting & Infrastructure Services
          </h1>
          <p class="text-lg text-slate-300 leading-relaxed mb-8">
            CogNexa provides practical, vendor-neutral IT consulting — from infrastructure audits and technology assessments to managed IT services and strategic technology roadmap planning for growing organizations.
          </p>
          <a href="/contact/" class="inline-flex items-center justify-center px-7 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-colors" data-event="cta_click" data-location="hero" data-service="IT Consulting">
            Get IT Assessment
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white mb-8 text-center">What we cover</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {[
            { title: "Infrastructure Audit", desc: "Review your current servers, networking, storage, and endpoints to identify gaps, risks, and optimization opportunities." },
            { title: "Technology Roadmap", desc: "Define a 12–36 month technology plan aligned to your business goals, budget, and growth expectations." },
            { title: "Vendor Selection", desc: "Evaluate and recommend technology vendors, cloud providers, and service partners without commercial bias." },
            { title: "Managed IT Support", desc: "Ongoing IT management, helpdesk support, and system maintenance for organizations without a dedicated IT team." },
          ].map((item) => (
            <div class="rounded-xl bg-slate-800 border border-slate-700 p-6">
              <h3 class="font-bold text-white mb-2">{item.title}</h3>
              <p class="text-sm text-slate-400 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <FAQ items={faqs} variant="dark" />
    <RelatedServices title="Other Services" items={related} variant="dark" />
    <CTASection
      title="Need practical IT advice?"
      description="Get a free IT assessment. We will review your current setup and give you honest, vendor-neutral recommendations."
      primaryLabel="Get Free IT Assessment"
      primaryHref="/contact/"
      variant="blue"
    />
  </div>
</MarketingLayout>
