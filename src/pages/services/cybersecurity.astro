---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import CTASection from "../../components/shared/CTASection.astro";
import FAQ from "../../components/shared/FAQ.astro";
import RelatedServices from "../../components/shared/RelatedServices.astro";
import ProductCard from "../../components/shared/ProductCard.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import { siteConfig } from "../../data/site";
import { cybersecurityFaqs } from "../../data/faqs";
import { cognexaServices } from "../../data/services";

const site = siteConfig.cognexa;
const sura = siteConfig.surakshitam;

const surakshitamProducts = [
  { name: "Kavach", title: "Managed Firewall", summary: "OPNsense-based managed firewall with VPN, IDS/IPS, and monitoring.", accentColor: "#3b82f6", href: `${sura.domain}/kavach-managed-firewall/` },
  { name: "Durg", title: "Vulnerability Scanner", summary: "Identify security weaknesses across networks, applications, and APIs.", accentColor: "#f59e0b", href: `${sura.domain}/durg-vulnerability-scanner/` },
  { name: "Shastra", title: "Penetration Testing", summary: "Manual security testing by certified professionals.", accentColor: "#ef4444", href: `${sura.domain}/shastra-penetration-testing/` },
  { name: "Raksha", title: "Web Application Firewall", summary: "Protect web applications from OWASP Top 10 threats.", accentColor: "#8b5cf6", href: `${sura.domain}/raksha-web-application-firewall/` },
  { name: "Setu", title: "Enterprise VPN", summary: "Secure remote access and site-to-site connectivity.", accentColor: "#10b981", href: `${sura.domain}/setu-enterprise-vpn/` },
  { name: "Pravesh", title: "Captive Portal", summary: "Controlled guest Wi-Fi with logging and authentication.", accentColor: "#f97316", href: `${sura.domain}/pravesh-captive-portal/` },
  { name: "Netra", title: "Network Monitoring", summary: "Continuous visibility into network and security events.", accentColor: "#06b6d4", href: `${sura.domain}/netra-network-monitoring/` },
];

const related = cognexaServices
  .filter((s) => s.slug !== "cybersecurity")
  .slice(0, 3)
  .map((s) => ({ name: s.name, summary: s.summary, href: `/services/${s.slug}/` }));
---

<MarketingLayout
  title="Cybersecurity Services in India | CogNexa"
  description="Comprehensive cybersecurity through the Surakshitam suite — managed firewall, vulnerability assessment, pen testing, WAF, VPN, captive portal, and monitoring."
>
  <div class="bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
      <Breadcrumbs
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Services", href: "/services/" },
          { label: "Cybersecurity" },
        ]}
        variant="dark"
      />
    </div>

    <!-- Hero -->
    <section class="pt-8 pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold text-cyan-400 uppercase tracking-widest mb-3">
            Cybersecurity Solutions
          </p>
          <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5 text-balance">
            Cybersecurity Services for Businesses in India
          </h1>
          <p class="text-lg text-slate-300 leading-relaxed mb-8">
            CogNexa delivers comprehensive cybersecurity through the Surakshitam suite — managed firewall, vulnerability assessment, penetration testing, WAF, VPN, captive portal, and 24/7 monitoring. Deployed and managed for organizations that need real security without building an internal SOC.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/contact/"
              class="inline-flex items-center justify-center px-7 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-colors"
              data-event="security_assessment_request"
              data-location="hero"
              data-service="Cybersecurity"
            >
              Get Free Security Assessment
            </a>
            <a
              href={sura.domain}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-7 py-3 border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-white font-medium rounded-lg transition-colors"
            >
              Explore Surakshitam
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Products grid -->
    <section class="py-16 bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-2xl md:text-3xl font-bold text-white">
            The Surakshitam Cybersecurity Suite
          </h2>
          <p class="mt-2 text-slate-400">
            Seven products covering every layer of your security needs.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {surakshitamProducts.map((p) => (
            <ProductCard
              name={p.name}
              title={p.title}
              summary={p.summary}
              accentColor={p.accentColor}
              href={p.href}
              cta="Learn More"
              variant="dark"
            />
          ))}
        </div>
        <div class="text-center mt-8">
          <a
            href={sura.domain}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-8 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-colors"
            data-event="service_card_click"
            data-location="products-grid"
            data-service="Surakshitam"
          >
            View Full Suite on Surakshitam.com
          </a>
        </div>
      </div>
    </section>

    <!-- Why choose us -->
    <section class="py-16 bg-slate-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">
              Why organizations choose CogNexa for cybersecurity
            </h2>
            <ul class="space-y-4">
              {[
                ["Fully managed", "We deploy, configure, monitor, and maintain — you focus on your business."],
                ["Open-source foundation", "Built on proven open-source platforms that eliminate vendor lock-in."],
                ["India-based team", "On-the-ground support, local language, and same-timezone response."],
                ["Compliance-ready", "Designed to support ISO 27001, PCI-DSS, and CERT-In requirements."],
              ].map(([title, desc]) => (
                <li class="flex items-start gap-3">
                  <span class="text-cyan-400 mt-0.5 text-lg shrink-0">✓</span>
                  <div>
                    <span class="font-semibold text-white">{title}: </span>
                    <span class="text-slate-400">{desc}</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
          <div class="rounded-2xl bg-slate-800 border border-slate-700 p-8">
            <h3 class="text-lg font-bold text-white mb-4">Not sure where to start?</h3>
            <p class="text-slate-400 mb-6">
              Book a free security assessment. We will review your current setup, identify the highest-risk areas, and recommend a practical next step.
            </p>
            <a
              href="/contact/"
              class="block text-center px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-colors"
              data-event="security_assessment_request"
              data-location="why-us-box"
            >
              Book Free Assessment
            </a>
            <div class="mt-4 text-center text-sm text-slate-500">
              or call <a href={`tel:${site.phoneRaw}`} class="text-cyan-400 hover:underline" data-event="phone_click" data-location="cybersecurity-page">{site.phone}</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <FAQ items={cybersecurityFaqs} variant="dark" />

    <RelatedServices
      title="Other Services"
      items={related}
      variant="dark"
    />

    <CTASection
      title="Ready to secure your organization?"
      description="Get a free security assessment. No commitment, no pressure — just a clear view of where you stand."
      primaryLabel="Get Free Security Assessment"
      primaryHref="/contact/"
      primaryEvent="security_assessment_request"
      variant="blue"
    />
  </div>
</MarketingLayout>
