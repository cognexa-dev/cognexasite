---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import CTASection from "../../components/shared/CTASection.astro";
import FAQ from "../../components/shared/FAQ.astro";
import RelatedServices from "../../components/shared/RelatedServices.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import LeadForm from "../../components/shared/LeadForm.astro";
import { cognexaServices } from "../../data/services";
import type { FAQ as FAQType } from "../../data/faqs";

const related = cognexaServices
  .filter((s) => !["vidya-ai"].includes(s.slug))
  .slice(0, 3)
  .map((s) => ({ name: s.name, summary: s.summary, href: `/services/${s.slug}/` }));

const faqs: FAQType[] = [
  { question: "What is a local LLM?", answer: "A local LLM (Large Language Model) is an AI language model that runs on your own servers, not on external cloud services. This means your documents and queries never leave your infrastructure. Vidya AI uses proven open-source LLM technology deployed on your hardware." },
  { question: "What documents can Vidya AI learn from?", answer: "Vidya AI can ingest PDFs, Word documents, Excel files, text files, and web pages. Common sources include HR manuals, SOPs, product catalogues, compliance documents, technical guides, and policy documents." },
  { question: "What hardware is required?", answer: "Requirements depend on the volume of documents and expected users. We assess your existing infrastructure and recommend an appropriate setup. Many organizations can run Vidya AI on existing servers without significant new hardware investment." },
  { question: "Can non-technical staff use Vidya AI?", answer: "Yes. Vidya AI provides a simple chat interface — users ask questions in plain language and get accurate answers from your documents. No technical training is required to use it." },
];

const useCases = [
  { industry: "Enterprises", use: "HR policy and compliance queries — instant answers from employee handbooks and policy documents." },
  { industry: "Manufacturing", use: "SOP access for operators — machine procedures, safety protocols, and quality standards on demand." },
  { industry: "Education", use: "Institutional knowledge base — curriculum, administrative policies, and regulatory guidelines." },
  { industry: "Healthcare", use: "Clinical protocol access — treatment guidelines, formularies, and administrative procedures." },
  { industry: "Government", use: "Policy and regulation queries — officers get accurate answers from official documents instantly." },
  { industry: "Support Teams", use: "Internal knowledge base — support staff get answers from product manuals and troubleshooting guides." },
];
---

<MarketingLayout
  title="Vidya AI — Local LLM Knowledge Base for Enterprises | CogNexa"
  description="Deploy a private AI knowledge base trained on your SOPs, manuals, and policies. Vidya AI runs entirely on your own servers — no cloud dependency. Request a demo."
>
  <div class="bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
      <Breadcrumbs
        crumbs={[
          { label: "Home", href: "/" },
          { label: "Services", href: "/services/" },
          { label: "Vidya AI" },
        ]}
        variant="dark"
      />
    </div>

    <section class="pt-8 pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div>
            <p class="text-sm font-semibold text-cyan-400 uppercase tracking-widest mb-3">Vidya AI</p>
            <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5 text-balance">
              Local AI Knowledge Base for Your Organization
            </h1>
            <p class="text-lg text-slate-300 leading-relaxed mb-6">
              Vidya AI lets your organization deploy an AI assistant trained on its own documents — SOPs, policy manuals, product catalogues, HR guides — that runs entirely on your servers. No data leaves your infrastructure.
            </p>
            <ul class="space-y-3 mb-8">
              {["100% private — runs on your servers", "Train on any internal document", "Plain-language answers from your actual policies", "No recurring cloud AI subscription fees"].map((b) => (
                <li class="flex items-center gap-3 text-slate-300">
                  <span class="text-cyan-400 shrink-0">✓</span>{b}
                </li>
              ))}
            </ul>
          </div>
          <div>
            <LeadForm
              title="Request Vidya AI Demo"
              subtitle="We will show you how Vidya AI works with your own documents."
              services={["Vidya AI Demo", "Local LLM Deployment", "AI Automation", "Custom AI Solution"]}
              variant="dark"
              compact={true}
            />
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-8 text-center">Who uses Vidya AI</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {useCases.map((u) => (
            <div class="rounded-xl bg-slate-800 border border-slate-700 p-6">
              <p class="text-xs font-bold text-cyan-400 uppercase tracking-wider mb-2">{u.industry}</p>
              <p class="text-sm text-slate-300 leading-relaxed">{u.use}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <FAQ items={faqs} variant="dark" />
    <RelatedServices title="Other Services" items={related} variant="dark" />
    <CTASection
      title="See Vidya AI with your own documents"
      description="Request a demo. We will show you how Vidya AI answers questions from your actual SOPs and manuals."
      primaryLabel="Request Demo"
      primaryHref="/contact/"
      variant="blue"
    />
  </div>
</MarketingLayout>
