---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import LeadForm from "../components/shared/LeadForm.astro";
import { siteConfig } from "../data/site";
import { cognexaServices } from "../data/services";

const site = siteConfig.cognexa;
const services = cognexaServices.map((s) => s.name);
---

<MarketingLayout
  title="Contact CogNexa — Request Free Consultation"
  description="Get in touch with CogNexa for cybersecurity, data management, AI automation, or custom development. Request a free consultation today."
>
  <section class="py-16 md:py-24 bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Left: info -->
        <div>
          <p class="text-sm font-semibold text-cyan-400 uppercase tracking-widest mb-3">
            Get In Touch
          </p>
          <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
            Request a Free Consultation
          </h1>
          <p class="text-slate-300 leading-relaxed mb-8">
            Tell us what you need and our team will get back to you within 24 hours. There is no commitment — just a straightforward conversation about your requirements.
          </p>

          <div class="space-y-5 mb-10">
            <div class="flex items-start gap-4">
              <span class="text-2xl">📞</span>
              <div>
                <p class="font-semibold text-white">Phone</p>
                <a
                  href={`tel:${site.phoneRaw}`}
                  class="text-cyan-400 hover:text-cyan-300 transition-colors"
                  data-event="phone_click"
                  data-location="contact-page"
                >
                  {site.phone}
                </a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-2xl">✉️</span>
              <div>
                <p class="font-semibold text-white">Email</p>
                <a
                  href={`mailto:${site.email}`}
                  class="text-cyan-400 hover:text-cyan-300 transition-colors"
                >
                  {site.email}
                </a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <span class="text-2xl">💬</span>
              <div>
                <p class="font-semibold text-white">WhatsApp</p>
                <a
                  href={site.whatsapp}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-cyan-400 hover:text-cyan-300 transition-colors"
                  data-event="whatsapp_click"
                  data-location="contact-page"
                >
                  Message Us on WhatsApp
                </a>
              </div>
            </div>
          </div>

          <div class="rounded-xl bg-slate-800 border border-slate-700 p-5">
            <p class="font-semibold text-white mb-2">What to expect</p>
            <ul class="space-y-1.5 text-sm text-slate-400">
              <li class="flex items-center gap-2"><span class="text-cyan-400">✓</span> Response within 24 hours</li>
              <li class="flex items-center gap-2"><span class="text-cyan-400">✓</span> No hard sell — just a conversation</li>
              <li class="flex items-center gap-2"><span class="text-cyan-400">✓</span> Clear next steps after first call</li>
              <li class="flex items-center gap-2"><span class="text-cyan-400">✓</span> Your information is kept private</li>
            </ul>
          </div>
        </div>

        <!-- Right: form -->
        <div>
          <LeadForm
            title="Send Your Request"
            subtitle="We will get back to you within 24 hours."
            services={services}
            variant="dark"
          />
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
