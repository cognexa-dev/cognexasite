---
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import CTASection from "../../components/shared/CTASection.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import { industries } from "../../data/industries";
---

<MarketingLayout
  title="Industries We Serve | CogNexa"
  description="CogNexa provides IT, cybersecurity, and AI solutions across education, healthcare, manufacturing, government, and hospitality sectors in India."
>
  <div class="bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-6">
      <Breadcrumbs crumbs={[{ label: "Home", href: "/" }, { label: "Industries" }]} variant="dark" />
    </div>

    <section class="pt-8 pb-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">Industries We Serve</h1>
          <p class="text-lg text-slate-400 max-w-2xl mx-auto">
            We work with organizations across multiple sectors, adapting our IT, cybersecurity, and data services to the specific requirements of each industry.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {industries.map((ind) => (
            <a
              href={`/industries/${ind.slug}/`}
              class="group block rounded-2xl border border-slate-700 bg-slate-800 p-6 hover:border-blue-600 hover:bg-slate-750 transition-all"
            >
              <h2 class="text-lg font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">
                {ind.name}
              </h2>
              <p class="text-sm text-slate-400 leading-relaxed mb-4">{ind.summary}</p>
              <span class="text-sm text-blue-400 group-hover:underline">View solutions →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTASection
      title="Not seeing your industry?"
      description="We work with businesses across many sectors. Tell us about your requirements and we will propose the right approach."
      primaryLabel="Request Free Consultation"
      primaryHref="/contact/"
      variant="blue"
    />
  </div>
</MarketingLayout>
