---
import MarketingLayout from "../layouts/MarketingLayout.astro";
---
<MarketingLayout
  title="Page Not Found | CogNexa"
  description="The page you are looking for could not be found."
  noindex={true}
>
  <section class="min-h-[70vh] flex items-center justify-center py-20 bg-slate-900">
    <div class="text-center px-4">
      <p class="text-6xl font-extrabold text-slate-700 mb-4">404</p>
      <h1 class="text-2xl font-bold text-white mb-3">Page not found</h1>
      <p class="text-slate-400 mb-8">The page you are looking for doesn't exist or has been moved.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg transition-colors">
          Back to Home
        </a>
        <a href="/contact/" class="px-6 py-2.5 border border-slate-600 hover:border-slate-400 text-slate-300 hover:text-white rounded-lg transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
