---
import BaseLayout from "./BaseLayout.astro";
import WhatsAppButton from "../components/shared/WhatsAppButton.astro";
import PhoneCTA from "../components/shared/PhoneCTA.astro";
import { siteConfig } from "../data/site";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | object[];
}

const props = Astro.props;
const { whatsapp, phone, phoneRaw, email, name } = siteConfig.cognexa;
const currentYear = new Date().getFullYear();
---

<BaseLayout {...props} noindex={true}>
  <!-- Minimal header — no distraction nav -->
  <header class="border-b border-slate-800 bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
      <a href="/" class="font-bold text-lg text-white" aria-label="CogNexa — Home">
        <span class="text-cyan-400">Cog</span>Nexa
      </a>
      <PhoneCTA
        phone={phone}
        phoneRaw={phoneRaw}
        variant="button"
        class="text-cyan-400 border-cyan-400 hover:bg-cyan-400 hover:text-slate-900 text-sm"
      />
    </div>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <!-- Minimal footer -->
  <footer class="bg-slate-950 border-t border-slate-800 py-6 text-center text-xs text-slate-600">
    <p>
      © {currentYear} {name} · <a href={`mailto:${email}`} class="hover:text-slate-400">{email}</a>
      · <a href="/privacy-policy/" class="hover:text-slate-400">Privacy Policy</a>
    </p>
  </footer>

  <WhatsAppButton href={whatsapp} />
</BaseLayout>
