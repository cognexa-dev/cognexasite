---
import { cognexaNav, cognexaCta } from "../../data/navigation";
import { siteConfig } from "../../data/site";

const { phone, phoneRaw } = siteConfig.cognexa;
const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-40 border-b border-slate-800 bg-slate-900/95 backdrop-blur-sm"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 font-bold text-xl text-white hover:text-cyan-400 transition-colors"
        aria-label="CogNexa — Home"
      >
        <span class="text-cyan-400">Cog</span>Nexa
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {
          cognexaNav.map((item) => (
            <div class="relative group">
              {item.children ? (
                <>
                  <button
                    class:list={[
                      "flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-md transition-colors",
                      "text-slate-300 hover:text-white hover:bg-slate-800",
                    ]}
                    aria-haspopup="true"
                  >
                    {item.label}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                      class="w-4 h-4 transition-transform group-hover:rotate-180"
                      aria-hidden="true"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </button>
                  <div class="absolute top-full left-0 mt-1 w-56 rounded-xl border border-slate-700 bg-slate-800 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
                    <ul class="py-1">
                      {item.children.map((child) => (
                        <li>
                          <a
                            href={child.href}
                            class:list={[
                              "block px-4 py-2.5 text-sm transition-colors",
                              currentPath === child.href
                                ? "text-cyan-400 bg-slate-700"
                                : "text-slate-300 hover:text-white hover:bg-slate-700",
                            ]}
                          >
                            {child.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                </>
              ) : (
                <a
                  href={item.href}
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener noreferrer" : undefined}
                  class:list={[
                    "px-3 py-2 text-sm font-medium rounded-md transition-colors",
                    currentPath === item.href
                      ? "text-cyan-400 bg-slate-800"
                      : "text-slate-300 hover:text-white hover:bg-slate-800",
                  ]}
                >
                  {item.label}
                </a>
              )}
            </div>
          ))
        }
      </nav>

      <!-- Desktop CTA + Phone -->
      <div class="hidden lg:flex items-center gap-3">
        <a
          href={`tel:${phoneRaw}`}
          class="text-sm text-slate-400 hover:text-white transition-colors"
          data-event="phone_click"
          data-location="header"
        >
          {phone}
        </a>
        <a
          href={cognexaCta.href}
          class="px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold rounded-lg transition-colors"
          data-event="cta_click"
          data-location="header"
        >
          {cognexaCta.label}
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md text-slate-400 hover:text-white hover:bg-slate-800 transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-6 h-6"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
          />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-slate-800 bg-slate-900"
  >
    <nav class="px-4 py-4 space-y-1" aria-label="Mobile navigation">
      {
        cognexaNav.map((item) => (
          <>
            <a
              href={item.children ? (item.children[0]?.href ?? item.href) : item.href}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noopener noreferrer" : undefined}
              class="block px-3 py-2 text-sm font-medium text-slate-300 hover:text-white hover:bg-slate-800 rounded-md"
            >
              {item.label}
            </a>
            {item.children &&
              item.children.map((child) => (
                <a
                  href={child.href}
                  class="block pl-6 pr-3 py-1.5 text-sm text-slate-400 hover:text-white hover:bg-slate-800 rounded-md"
                >
                  {child.label}
                </a>
              ))}
          </>
        ))
      }
      <div class="pt-3 border-t border-slate-800 flex flex-col gap-2">
        <a
          href={`tel:${phoneRaw}`}
          class="flex items-center gap-2 px-3 py-2 text-sm text-slate-300 hover:text-white"
          data-event="phone_click"
          data-location="mobile-menu"
        >
          📞 {phone}
        </a>
        <a
          href={cognexaCta.href}
          class="block text-center px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold rounded-lg transition-colors"
          data-event="cta_click"
          data-location="mobile-menu"
        >
          {cognexaCta.label}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(isOpen));
  });
</script>
